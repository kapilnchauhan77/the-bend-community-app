# ─────────────────────────────────────────────────────────────
# The Bend Community — Production VM Deployment
# Copy this to .env and fill in real values before running deploy.sh
# ─────────────────────────────────────────────────────────────

# === Domain ===
BASE_DOMAIN=bend.community
ACME_EMAIL=admin@bend.community
# Cloudflare API token scoped to: Zone:Zone:Read + Zone:DNS:Edit on bend.community
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# === Frontend build args (baked into the Vite build) ===
VITE_API_URL=https://api.bend.community/api/v1
VITE_BASE_DOMAIN=bend.community

# === Backend ===
APP_ENV=production
DEBUG=false
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_32_CHAR_STRING
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_32_CHAR_STRING
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — wildcard subdomains handled by allow_origin_regex in main.py
CORS_ORIGINS=["https://bend.community"]

# Frontend URL used for Stripe redirects and email links (default tenant)
FRONTEND_URL=https://westmoreland.bend.community

# === Postgres ===
POSTGRES_DB=thebend
POSTGRES_USER=thebend
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# === Super Admin (created by seed on first boot) ===
SUPER_ADMIN_EMAIL=super@bend.community
SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_8

# === Stripe ===
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# === SendGrid ===
SENDGRID_API_KEY=
EMAIL_FROM=support@bend.community
EMAIL_FROM_NAME=The Bend Community

# === AWS S3 (optional — for upload storage) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# === Web Push (VAPID) — optional ===
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@bend.community
